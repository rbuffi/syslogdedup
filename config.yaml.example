# Example configuration file for syslog deduplication service
# Copy this file to config.yaml and update with your settings

syslog:
  listen_port: 514  # UDP port to listen on (requires root/sudo for port < 1024)
  forward_enabled: true  # Set to false to disable downstream syslog forwarding
  forward_host: "downstream-syslog.example.com"  # Downstream syslog server hostname or IP
  forward_port: 514  # Downstream syslog server port
  use_tcp: false  # Set to true to forward logs over TCP instead of UDP

nsxt:
  host: "nsxt-manager.example.com"  # NSX-T Manager hostname or IP
  username: "admin"  # NSX-T Manager username
  password: "your-password-here"  # NSX-T Manager password
  verify_ssl: true  # Verify SSL certificates (set to false for self-signed certs)
  cache_ttl: 3600  # Cache group lookups for 1 hour (in seconds)

influx:
  enabled: false  # Set to true to enable InfluxDB writing
  host: "localhost"  # InfluxDB host
  port: 8086  # InfluxDB HTTP port
  database: "firewall"  # InfluxDB database name
  username: ""  # InfluxDB username (optional)
  password: ""  # InfluxDB password (optional)
  measurement: "firewall_logs"  # InfluxDB measurement name

postgres:
  enabled: false  # Set to true to enable PostgreSQL writing
  host: "localhost"
  port: 5432
  database: "firewall"
  user: "firewall_user"
  password: "your-password-here"
  table: "flows"

# Optional: public URL path prefix when the Web UI is behind a reverse proxy subpath (same as WEB_BASE_PATH env).
# web:
#   base_path: "/syslogdedup"

# Optional: OIDC login for the Web UI (e.g. Keycloak). When enabled, / and /api/* require a session.
# oidc:
#   enabled: true
#   issuer: "https://keycloak.example.com/realms/myrealm"
#   client_id: "firewall-ui"
#   client_secret: "your-client-secret"
#   redirect_uri: "http://localhost:8080/auth/callback"  # include web.base_path if used, e.g. http://localhost:8080/syslog/auth/callback
#   ssl_verify: true   # set false or OIDC_SSL_VERIFY=false if Keycloak uses a private CA
#   scope: "openid email profile"
#   session_secret: "long-random-string-for-cookie-signing"

