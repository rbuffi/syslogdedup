# Copy to .env and adjust. Used by docker compose.

POSTGRES_USER=firewall
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=firewall

# Host port published for the web UI (container still listens on 8080)
WEB_PUBLISH_PORT=8080

# --- Optional: profile `syslog` (docker compose --profile syslog up) ---
# SYSLOG_UDP_PORT=514
# SYSLOG_FORWARD_HOST=downstream-syslog.example.com
# SYSLOG_FORWARD_PORT=514
# NSXT_HOST=nsxt-manager.example.com
# NSXT_USERNAME=admin
# NSXT_PASSWORD=secret
# SYSLOG_PG_ENABLED=true
# SYSLOG_PG_HOST=postgres
